{
  "name": "northlumedistribution-ca",
  "version": "0.1.0",
  "description": "Static website for North Lume Distribution - product distribution company",
  "private": true,
  "type": "module",
  "author": {
    "name": "OurMedia",
    "email": "dev@ourmedia.ca"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:report": "playwright show-report",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,ts,vue,json,css,scss,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,json,css,scss,md,yml,yaml}\"",
    "check": "npm run lint && npm run test:run",
    "process-catalog": "python3 scripts/process-catalog.py",
    "generate-assets": "python3 scripts/generate-brand-assets.py",
    "prepare": "husky"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-i18n": "9",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.29.0",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.5.0"
}
